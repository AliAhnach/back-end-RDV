# Clé secrète Flask (obligatoire en production)
SECRET_KEY=your-very-secret-key-here

# Option 1 : URL complète de la base de données (Railway l'injecte automatiquement)
DATABASE_URL=mysql+pymysql://user:password@host:port/database

# Option 2 : variables individuelles MySQL (Railway MySQL plugin)
MYSQLHOST=your-mysql-host
MYSQLPORT=3306
MYSQLUSER=your-mysql-user
MYSQLPASSWORD=your-mysql-password
MYSQLDATABASE=your-database-name

# Origines autorisées pour CORS (séparées par des virgules)
CORS_ORIGINS=https://your-frontend.netlify.app

# Développement local uniquement
FLASK_DEBUG=false
LOCAL_DATABASE_URL=mysql+pymysql://rdv_user:rdv_password@localhost/rdv_db
